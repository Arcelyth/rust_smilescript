var x = "global";
fun outer() {
    var x = "outer";
    fun inner() {
        print x;
    }
    inner();
}
outer();

var globalSet;
var globalGet;
fun main() {
    var a = "initial";
    fun set() { a = "updated"; }
    fun get() { print a; }
    globalSet = set;
    globalGet = get;
}
main();
globalSet();
globalGet();
